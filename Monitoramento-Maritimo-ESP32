#include <Wire.h>
#include <SPI.h>
#include <SD.h>
#include <INA226.h>
#include <OneWire.h>
#include <DallasTemperature.h>
#include <math.h>

// =====================================================
// TELEMETRIA INTELIGENTE - BARCO SOLAR DSB
// =====================================================

#define SD_CS                5
#define ONE_WIRE_BUS         4

// Bateria
#define VOLT_MIN             21.0
#define VOLT_MAX             26.5
#define CAPACIDADE_AH        40.0

// Filtro
#define AMOSTRAS             15

// Segurança
#define TEMP_ALERTA          50.0
#define TEMP_CRITICA         60.0
#define SOC_ALERTA           15.0
#define SOC_CRITICO          5.0
#define VOLT_SOBRETENSAO     28.0

// Estratégia
#define VELOCIDADE_MAX       25.0
#define VELOCIDADE_MIN       5.0

// =====================================================
// INSTÂNCIAS
// =====================================================

INA226 ina;
OneWire oneWire(ONE_WIRE_BUS);
DallasTemperature sensors(&oneWire);
File arquivo;

// =====================================================
// VARIÁVEIS GLOBAIS
// =====================================================

// Sensores
float voltagem = 0.0;
float corrente = 0.0;
float potencia = 0.0;
float temperatura = 25.0;

// Energia
float soc = 100.0;
float consumoAh = 0.0;
float autonomiaHoras = 0.0;

// Estratégia
float distanciaRestante = 12.5;
float tempoProvaRestante = 1.8;
float velocidadeAtual = 0.0;
float velocidadeIdeal = 0.0;

// Filtros
float leiturasV[AMOSTRAS];
float leiturasI[AMOSTRAS];
float leiturasT[AMOSTRAS];

int indiceLeitura = 0;

// Tempo
unsigned long ultimoTempo = 0;
unsigned long tempoAnterior = 0;

float deltaTempo = 0.0;

unsigned long tempoSegundos = 0;
unsigned long uptimeMin = 0;

// Hardware
bool sdDisponivel = false;
bool inaDisponivel = false;

// Controle de prints
bool flagEconomia = false;
bool flagTermica = false;

int ultimoRitmo = -1;

// =====================================================
// ESTADOS
// =====================================================

enum EstadoSistema {
  NORMAL,
  ALERTA,
  CRITICO
};

EstadoSistema estadoAtual = NORMAL;
EstadoSistema ultimoEstadoPrintado = NORMAL;

bool primeiroLoopEstado = true;

// =====================================================
// FILTRO MÉDIA MÓVEL
// =====================================================

float filtrar(float novaLeitura, float *array, int indice) {

  array[indice] = novaLeitura;

  float soma = 0.0;

  for (int i = 0; i < AMOSTRAS; i++) {
    soma += array[i];
  }

  return soma / AMOSTRAS;
}

// =====================================================
// SETUP
// =====================================================

void setup() {

  Serial.begin(115200);

  Wire.begin();
  Wire.setClock(100000);

  Serial.println();
  Serial.println("=================================");
  Serial.println(" TELEMETRIA DSB PRO v2.9");
  Serial.println("=================================");

  // Inicializa filtros
  for (int i = 0; i < AMOSTRAS; i++) {

    leiturasV[i] = VOLT_MAX;
    leiturasI[i] = 0.0;
    leiturasT[i] = 25.0;
  }

  // INA226
  if (!ina.begin()) {

    Serial.println("ERRO: INA226 nao detectado!");

  } else {

    inaDisponivel = true;

    ina.configure(
      INA226_AVERAGES_16,
      INA226_BUS_CONV_TIME_1100US,
      INA226_SHUNT_CONV_TIME_1100US,
      INA226_MODE_SHUNT_BUS_CONT
    );

    ina.calibrate(0.002, 20);

    Serial.println("INA226 OK");
  }

  // DS18B20
  sensors.begin();

  Serial.println("DS18B20 OK");

  // SD CARD
  if (SD.begin(SD_CS)) {

    sdDisponivel = true;

    Serial.println("SD CARD OK");

    if (!SD.exists("/log_dsb.csv")) {

      arquivo = SD.open("/log_dsb.csv", FILE_WRITE);

      if (arquivo) {

        arquivo.println("tempo_s,tempo_m,delta_t,voltagem,corrente,potencia,soc,autonomia_h,temperatura,velocidade_ideal,estado");

        arquivo.close();
      }
    }

  } else {

    Serial.println("AVISO: SD CARD nao detectado!");
  }

  Serial.println("Sistema iniciado!");
}

// =====================================================
// LOOP PRINCIPAL
// =====================================================

void loop() {

  if (millis() - ultimoTempo >= 1000) {

    ultimoTempo = millis();

    deltaTempo = (millis() - tempoAnterior) / 1000.0;

    tempoAnterior = millis();

    tempoSegundos = millis() / 1000;
    uptimeMin = millis() / 60000;

    lerSensores();

    processarDados();

    calcularEstrategia();

    verificarAlertas();

    enviarTelemetria();

    if (sdDisponivel) {
      salvarSD();
    }
  }
}

// =====================================================
// LEITURA DOS SENSORES
// =====================================================

void lerSensores() {

  if (inaDisponivel) {

    float leituraV = ina.readBusVoltage();
    float lecturaI = ina.readShuntCurrent();

    voltagem = filtrar(leituraV, leiturasV, indiceLeitura);

    corrente = filtrar(lecturaI, leiturasI, indiceLeitura);

    potencia = fabs(voltagem * corrente);
  }

  sensors.requestTemperatures();

  float leituraT = sensors.getTempCByIndex(0);

  if (leituraT != DEVICE_DISCONNECTED_C) {

    temperatura = filtrar(leituraT, leiturasT, indiceLeitura);
  }

  indiceLeitura++;

  if (indiceLeitura >= AMOSTRAS) {
    indiceLeitura = 0;
  }
}

// =====================================================
// PROCESSAMENTO
// =====================================================

void processarDados() {

  if (inaDisponivel && corrente > 0.0) {

    float consAhes = (corrente * deltaTempo) / 3600.0;

    consumoAh += consAhes;
  }

  soc = ((CAPACIDADE_AH - consumoAh) / CAPACIDADE_AH) * 100.0;

  if (corrente > 0.05) {

    autonomiaHoras =
      (CAPACIDADE_AH * (soc / 100.0)) / corrente;

  } else {

    autonomiaHoras = 99.9;
  }

  if (voltagem <= VOLT_MIN && inaDisponivel) {

    soc = 0.0;

    autonomiaHoras = 0.0;
  }

  if (soc > 100.0) soc = 100.0;
  if (soc < 0.0) soc = 0.0;
}

// =====================================================
// ESTRATÉGIA DE PROVA
// =====================================================

void calcularEstrategia() {

  if (tempoProvaRestante > 0.0) {

    velocidadeIdeal =
      distanciaRestante / tempoProvaRestante;

  } else {

    velocidadeIdeal = 0.0;
  }

  if (velocidadeIdeal > VELOCIDADE_MAX)
    velocidadeIdeal = VELOCIDADE_MAX;

  if (velocidadeIdeal < VELOCIDADE_MIN &&
      velocidadeIdeal > 0.0)
    velocidadeIdeal = VELOCIDADE_MIN;

  // Economia
  if (soc < 20.0) {

    velocidadeIdeal *= 0.85;

    if (!flagEconomia) {

      Serial.println("[ESTRATEGIA] MODO ECONOMIA ATIVADO");

      flagEconomia = true;
    }

  } else {

    flagEconomia = false;
  }

  // Proteção térmica
  if (temperatura > 55.0) {

    velocidadeIdeal *= 0.70;

    if (!flagTermica) {

      Serial.println("[ESTRATEGIA] PROTECAO TERMICA ATIVADA");

      flagTermica = true;
    }

  } else {

    flagTermica = false;
  }

  // Ritmo
  if (velocidadeAtual < velocidadeIdeal) {

    if (ultimoRitmo != 0) {

      Serial.println("[RITMO] ABAIXO DA VELOCIDADE IDEAL");

      ultimoRitmo = 0;
    }

  } else {

    if (ultimoRitmo != 1) {

      Serial.println("[RITMO] RITMO DE PROVA OK");

      ultimoRitmo = 1;
    }
  }
}

// =====================================================
// TELEMETRIA JSON
// =====================================================

void enviarTelemetria() {

  Serial.print("{");

  Serial.print("\"tempo_s\":");
  Serial.print(tempoSegundos);

  Serial.print(",\"tempo_m\":");
  Serial.print(uptimeMin);

  Serial.print(",\"dt\":");
  Serial.print(deltaTempo, 3);

  Serial.print(",\"v\":");
  Serial.print(voltagem, 2);

  Serial.print(",\"i\":");
  Serial.print(corrente, 2);

  Serial.print(",\"p\":");
  Serial.print(potencia, 1);

  Serial.print(",\"soc\":");
  Serial.print(soc, 1);

  Serial.print(",\"aut_h\":");
  Serial.print(autonomiaHoras, 1);

  Serial.print(",\"t\":");
  Serial.print(temperatura, 1);

  Serial.print(",\"v_ideal\":");
  Serial.print(velocidadeIdeal, 1);

  Serial.print(",\"estado\":\"");

  switch (estadoAtual) {

    case NORMAL:
      Serial.print("NORMAL");
      break;

    case ALERTA:
      Serial.print("ALERTA");
      break;

    case CRITICO:
      Serial.print("CRITICO");
      break;
  }

  Serial.println("\"}");
}

// =====================================================
// SALVAR CSV
// =====================================================

void salvarSD() {

  arquivo = SD.open("/log_dsb.csv", FILE_WRITE);

  if (arquivo) {

    arquivo.print(tempoSegundos);
    arquivo.print(",");

    arquivo.print(uptimeMin);
    arquivo.print(",");

    arquivo.print(deltaTempo, 3);
    arquivo.print(",");

    arquivo.print(voltagem, 2);
    arquivo.print(",");

    arquivo.print(corrente, 2);
    arquivo.print(",");

    arquivo.print(potencia, 1);
    arquivo.print(",");

    arquivo.print(soc, 1);
    arquivo.print(",");

    arquivo.print(autonomiaHoras, 1);
    arquivo.print(",");

    arquivo.print(temperatura, 1);
    arquivo.print(",");

    arquivo.print(velocidadeIdeal, 1);
    arquivo.print(",");

    arquivo.println((int)estadoAtual);

    arquivo.close();
  }
}

// =====================================================
// ALERTAS E SEGURANÇA
// =====================================================

void verificarAlertas() {

  estadoAtual = NORMAL;

  if (
    temperatura >= TEMP_CRITICA ||
    soc <= SOC_CRITICO ||
    voltagem >= VOLT_SOBRETENSAO
  ) {

    estadoAtual = CRITICO;

  } else if (
    temperatura >= TEMP_ALERTA ||
    soc <= SOC_ALERTA
  ) {

    estadoAtual = ALERTA;
  }

  if (!inaDisponivel) {
    estadoAtual = CRITICO;
  }

  if (
    estadoAtual != ultimoEstadoPrintado ||
    primeiroLoopEstado
  ) {

    primeiroLoopEstado = false;

    ultimoEstadoPrintado = estadoAtual;

    if (estadoAtual == CRITICO) {

      if (!inaDisponivel) {

        Serial.println("!!! CRITICO: INA226 DESCONECTADO OU FALHOU !!!");

      } else {

        Serial.println("!!! STATUS: CRITICO (Verifique Alertas Mecanicos/Eletricos) !!!");
      }

    } else if (estadoAtual == ALERTA) {

      Serial.println("!! STATUS: ALERTA (Atencao aos parametros) !!");

    } else {

      Serial.println("[STATUS: SISTEMA NORMAL]");
    }
  }
}
